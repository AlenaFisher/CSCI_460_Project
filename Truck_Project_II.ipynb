      "outputs": [],
      "source": [
        "# Convert categorical class labels into numeric format\n",
        "# \"neg\" (no APS failure) -> 0\n",
        "# \"pos\" (APS failure) -> 1\n",
        "y_train = y_train.map({\"neg\":0, \"pos\":1})\n",
        "\n",
        "y_test = y_test.map({\"neg\":0, \"pos\":1})"
      ]
