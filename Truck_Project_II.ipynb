      "outputs": [],
      "source": [
        "\"\"\"\n",
        "Load the APS datasets for training and testing. The first 20 contain data\n",
        "that is not needed (descriptions, attribute information) rather than observational data.\n",
        "The first 20 rows are skipped to ensure that only the relevant data is considered for the models.\n",
        "\"\"\"\n",
        "\n",
        "df_training = pd.read_csv(\"aps_failure_training_set.csv\", skiprows=20)\n",
        "df_test = pd.read_csv(\"aps_failure_test_set.csv\", skiprows=20)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "xfrOiK8xTyCM"
      },
      "outputs": [],
      "source": [
        "\"\"\"\n",
        "Replace all occurences of the string \"na\" with Numpy NaN values. Missing\n",
        "values in this dataset are represented as the string \"na\"; converting them\n",
        "ensures compatability with all built-in pandas functions for proper preprocessing.\n",
        "\"\"\"\n",
        "df_training.replace(\"na\", np.nan, inplace=True)\n",
        "df_test.replace(\"na\", np.nan, inplace=True)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "07sHT5CAT4zR",
